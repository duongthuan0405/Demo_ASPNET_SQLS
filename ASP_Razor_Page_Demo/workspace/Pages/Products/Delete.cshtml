@page
@model workspace.Pages.Products.DeleteModel

<h1>Xóa Product</h1>
<h3>Bạn có chắc chắn muốn xóa mục này?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Tên</dt>
        <dd class="col-sm-10">@Model.Product.Name</dd>
        <dt class="col-sm-2">Mô tả</dt>
        <dd class="col-sm-10">@Model.Product.Description</dd>
        <dt class="col-sm-2">Giá</dt>
        <dd class="col-sm-10">@Model.Product.Price</dd>
        <dt class="col-sm-2">Category</dt>
        <dd class="col-sm-10">@Model.Product.Category?.Name</dd>
    </dl>
    
    <form method="post" asp-page-handler="Delete">
        <input type="hidden" asp-for="Product.Id" />
        <input type="submit" value="Xóa" class="btn btn-danger" /> |
        <a asp-page="./Index">Quay lại</a>
    </form>
</div>
