@page
@model workspace.Pages.Categories.EditModel

<h1>Sửa Category</h1>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <input type="hidden" asp-for="Category.Id" />
            <div class="form-group mb-3">
                <label asp-for="Category.Name" class="control-label">Tên</label>
                <input asp-for="Category.Name" class="form-control" />
                <span asp-validation-for="Category.Name" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Category.Description" class="control-label">Mô tả</label>
                <input asp-for="Category.Description" class="form-control" />
                <span asp-validation-for="Category.Description" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Lưu" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>
<div>
    <a asp-page="./Index">Quay lại danh sách</a>
</div>
